# AI Service Environment Variables
# Copy this file to .env and fill in your values

# Shared secret — must match AI_API_KEY in backend/.env
AI_API_KEY=your_ai_service_shared_secret_here

# Path to the pre-trained Random Forest model artifact
MODEL_PATH=model_artifacts/random_forest_model.pkl

# Path to the fitted feature scaler artifact
SCALER_PATH=model_artifacts/feature_scaler.pkl

# Server port (Render injects $PORT automatically)
PORT=8000
